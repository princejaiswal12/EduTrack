<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Manage Exams</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
  body { margin:0; font-family:'Segoe UI'; background:#f4f7fa; }

  header {
    background:#0a2540;
    color:white;
    padding:15px 30px;
  }

  .container { display:flex; }

  .sidebar {
    width:220px;
    background:#0a2540;
    color:white;
    min-height:100vh;
    padding:20px;
  }

  .sidebar a {
    display:block;
    color:white;
    margin:10px 0;
    text-decoration:none;
    padding:8px;
    border-radius:6px;
  }

  .sidebar a:hover { background:#4caf50; }

  .main { flex:1; padding:25px; }

  .card {
    background:white;
    padding:20px;
    border-radius:12px;
    margin-bottom:20px;
    box-shadow:0 5px 12px rgba(0,0,0,0.1);
  }

  input, select {
    width:100%;
    padding:10px;
    margin:8px 0;
    border-radius:6px;
    border:1px solid #ccc;
  }

  .add-btn {
    background:#4caf50;
    color:white;
    width:100%;
    padding:10px;
    border:none;
    border-radius:6px;
  }

  table {
    width:100%;
    border-collapse:collapse;
    background:white;
    border-radius:12px;
    overflow:hidden;
  }

  th {
    background:#0a2540;
    color:white;
    padding:10px;
  }

  td {
    padding:10px;
    text-align:center;
  }

  .btn {
    padding:6px 10px;
    border:none;
    color:white;
    border-radius:6px;
  }

  .edit { background:#2196f3; }
  .delete { background:#f44336; }

</style>
</head>

<body>

<header>
  <h2>📝 Manage Exams</h2>
</header>

<div class="container">

<!-- SIDEBAR -->
<div class="sidebar">
  <a href="/admin/dashboard">Dashboard</a>
  <a href="/students">Students</a>
  <a href="/teachers">Teachers</a>
  <a href="/subjects">Subjects</a>
  <a href="/exams">Exams</a>
</div>

<!-- MAIN -->
<div class="main">

<!-- ADD EXAM -->
<div class="card">
  <h3>Add Exam</h3>

  <form action="/exams" method="POST">

    <input name="exam[examName]" placeholder="Exam Name" required>

    <input type="date" name="exam[examDate]" required>

    <select name="exam[class]">
      <option>Class 10</option>
      <option>Class 11</option>
      <option>Class 12</option>
      <option>B.Sc</option>
    </select>

    <select name="exam[subject]">
      <% subjects.forEach(s => { %>
        <option><%= s.subjectName %></option>
      <% }) %>
    </select>

    <select name="exam[examType]">
      <option>Mid Term</option>
      <option>Final</option>
      <option>Unit Test</option>
      <option>Practical</option>
    </select>

    <button class="add-btn">Add Exam</button>
  </form>
</div>

<!-- TABLE -->
<table>
  <tr>
    <th>Name</th>
    <th>Date</th>
    <th>Class</th>
    <th>Subject</th>
    <th>Type</th>
    <th>Action</th>
  </tr>

  <% exams.forEach(e => { %>
    <tr>
      <td><%= e.examName %></td>
      <td><%= e.examDate.toISOString().split("T")[0] %></td>
      <td><%= e.class %></td>
      <td><%= e.subject %></td>
      <td><%= e.examType %></td>

      <td>
        <!-- EDIT -->
        <a href="/exams/<%= e._id %>/edit">
          <button class="btn edit">Edit</button>
        </a>

        <!-- DELETE -->
        <form action="/exams/<%= e._id %>?_method=DELETE"
              method="POST" style="display:inline;">
          <button class="btn delete">Delete</button>
        </form>
      </td>
    </tr>
  <% }) %>

</table>

</div>
</div>

</body>
</html>