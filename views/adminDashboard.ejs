<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Admin Dashboard</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
  body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: #f4f7fa;
  }

  /* HEADER */
  header {
    background: #0a2540;
    color: white;
    padding: 15px 30px;
    display: flex;
    justify-content: space-between;
  }

  .logout-btn {
    background: #f44336;
    border: none;
    padding: 8px 15px;
    border-radius: 6px;
    color: white;
    cursor: pointer;
  }

  /* LAYOUT */
  .container {
    display: flex;
  }

  /* SIDEBAR */
  .sidebar {
    width: 230px;
    background: #0a2540;
    color: white;
    min-height: 100vh;
    padding: 20px;
  }

  .sidebar h3 {
    color: #4caf50;
    margin-bottom: 20px;
  }

  .sidebar a {
    display: block;
    padding: 10px;
    margin: 8px 0;
    color: white;
    text-decoration: none;
    border-radius: 6px;
  }

  .sidebar a:hover {
    background: #4caf50;
  }

  /* MAIN */
  .main {
    flex: 1;
    padding: 25px;
  }

  /* STATS */
  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
  }

  .card {
    background: white;
    padding: 20px;
    border-radius: 12px;
    text-align: center;
    box-shadow: 0px 5px 12px rgba(0,0,0,0.1);
    transition: 0.2s;
    cursor: pointer;
  }

  .card:hover {
    transform: translateY(-5px);
  }

  .card h2 {
    margin: 10px 0;
    color: #0a2540;
  }

  .card p {
    color: gray;
  }

  /* QUICK LINKS */
  .modules {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
  }

  .module {
    background: white;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0px 5px 12px rgba(0,0,0,0.1);
    text-align: center;
    cursor: pointer;
    transition: 0.2s;
  }

  .module:hover {
    background: #4caf50;
    color: white;
  }

</style>
</head>

<body>

<header>
  <h2>📊 Admin Dashboard</h2>
  <a href="/">
    <button class="logout-btn">Logout</button>
  </a>
</header>

<div class="container">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <h3>Admin Panel</h3>
    <a href="/admin/dashboard">Dashboard</a>
    <a href="/students">Students</a>
    <a href="/teachers">Teachers</a>
    <a href="/subjects">Subjects</a>
    <a href="/timetables">Timetable</a>
    <a href="/exams">Exams</a>
    <a href="/fees">Fees</a>
    <a href="/hostels">Hostels</a>
  </div>

  <!-- MAIN -->
  <div class="main">

    <h2>Welcome Admin 👋</h2>
    <p>Overview of your ERP system</p>

    <!-- STATS -->
    <div class="stats">

      <div class="card">
        <h2><%= totalStudents %></h2>
        <p>Students</p>
      </div>

      <div class="card">
        <h2><%= totalTeachers %></h2>
        <p>Teachers</p>
      </div>

      <div class="card">
        <h2><%= totalSubjects %></h2>
        <p>Subjects</p>
      </div>

      <div class="card">
        <h2><%= totalExams %></h2>
        <p>Exams</p>
      </div>

      <div class="card">
        <h2><%= totalFees %></h2>
        <p>Fee Records</p>
      </div>

      <div class="card">
        <h2><%= totalHostel %></h2>
        <p>Hostels</p>
      </div>

      <div class="card">
        <h2><%= totalTimetables %></h2>
        <p>Timetable Entries</p>
      </div>

    </div>

    <!-- QUICK MODULE ACCESS -->
    <h3>Manage Modules</h3>

    <div class="modules">

      <div class="module" onclick="location.href='/students'">👨‍🎓 Students</div>
      <div class="module" onclick="location.href='/teachers'">👩‍🏫 Teachers</div>
      <div class="module" onclick="location.href='/subjects'">📚 Subjects</div>
      <div class="module" onclick="location.href='/timetables'">📅 Timetable</div>
      <div class="module" onclick="location.href='/exams'">📝 Exams</div>
      <div class="module" onclick="location.href='/fees'">💰 Fees</div>
      <div class="module" onclick="location.href='/hostels'">🏠 Hostels</div>

    </div>

  </div>

</div>

</body>
</html>