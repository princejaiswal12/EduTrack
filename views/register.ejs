<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Register - ERP</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
  body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: linear-gradient(135deg, #4caf50, #0a2540);
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
  }

  .card {
    background: white;
    padding: 35px;
    border-radius: 12px;
    width: 350px;
    box-shadow: 0px 10px 30px rgba(0,0,0,0.2);
    text-align: center;
  }

  h2 {
    margin-bottom: 20px;
    color: #0a2540;
  }

  input, select {
    width: 100%;
    padding: 10px;
    margin: 8px 0;
    border-radius: 6px;
    border: 1px solid #ccc;
  }

  button {
    width: 100%;
    padding: 12px;
    background: #0a2540;
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: bold;
    cursor: pointer;
    margin-top: 10px;
  }

  button:hover {
    background: #071a2d;
  }

  .switch {
    margin-top: 15px;
  }

  .switch a {
    color: #4caf50;
    font-weight: bold;
    text-decoration: none;
  }

</style>
</head>

<body>

<div class="card">
  <h2>Register</h2>

  <form method="POST" action="/register">

    <select name="role">
      <option value="student">Student</option>
      <option value="teacher">Teacher</option>
    </select>

    <input type="text" name="name" placeholder="Full Name" required>
    <input type="email" name="email" placeholder="Email" required>

    <button type="submit">Register</button>
  </form>

  <div class="switch">
    Already have an account?
    <a href="/login">Login</a>
  </div>
</div>

</body>
</html>