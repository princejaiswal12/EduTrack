<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Register</title>

<style>
body {
  margin:0;
  font-family:'Segoe UI';
  background: linear-gradient(135deg,#0a2540,#4caf50);
  height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
}

.box {
  background:white;
  padding:30px;
  border-radius:12px;
  width:380px;
}

h2 { text-align:center; }

input, select {
  width:100%;
  padding:10px;
  margin:8px 0;
  border-radius:6px;
  border:1px solid #ccc;
}

button {
  width:100%;
  padding:10px;
  background:#4caf50;
  color:white;
  border:none;
  border-radius:6px;
}

.hidden { display:none; }

.switch {
  text-align:center;
  margin-top:10px;
}
</style>
</head>

<body>

<div class="box">

<h2>Register</h2>

<form action="/register" method="POST">

<select name="role" id="role" onchange="toggleForm()" required>
  <option value="">Select Role</option>
  <option value="admin">Admin</option>
  <option value="teacher">Teacher</option>
  <option value="student">Student</option>
</select>

<!-- COMMON -->
<input name="name" placeholder="Full Name" required>
<input name="email" placeholder="Email" required>

<!-- STUDENT -->
<div id="studentFields" class="hidden">
  <input name="rollNumber" placeholder="Roll Number">
  <input name="studentPhone" placeholder="Phone">
  <input name="class" placeholder="Class">
  <input name="hostel" placeholder="Hostel">
</div>

<!-- TEACHER -->
<div id="teacherFields" class="hidden">
  <input name="teacherPhone" placeholder="Phone">
  <input name="subject" placeholder="Subject">
  <input name="department" placeholder="Department">
</div>

<button>Register</button>

</form>

<div class="switch">
  Already have account? <a href="/login">Login</a>
</div>

</div>

<script>
function toggleForm() {
  const role = document.getElementById("role").value;

  const student = document.getElementById("studentFields");
  const teacher = document.getElementById("teacherFields");

  // show/hide
  student.style.display = role === "student" ? "block" : "none";
  teacher.style.display = role === "teacher" ? "block" : "none";

  // disable unused inputs (IMPORTANT FIX)
  student.querySelectorAll("input").forEach(i => {
    i.disabled = role !== "student";
  });

  teacher.querySelectorAll("input").forEach(i => {
    i.disabled = role !== "teacher";
  });
}
</script>

</body>
</html>