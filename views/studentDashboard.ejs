<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Student Dashboard</title>

<style>
* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family:'Segoe UI';
  background:#f4f7fa;
}

/* HEADER */
header {
  background:#0a2540;
  color:white;
  padding:15px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.menu-btn {
  font-size:22px;
  cursor:pointer;
  display:none;
}

/* LAYOUT */
.container {
  display:flex;
}

/* SIDEBAR */
.sidebar {
  width:250px;
  background:#0a2540;
  color:white;
  min-height:100vh;
  padding:20px;
  transition:0.3s;
}

.sidebar a {
  display:block;
  color:white;
  text-decoration:none;
  padding:10px;
  margin:5px 0;
  border-radius:6px;
}

.sidebar a:hover {
  background:#4caf50;
}

/* MAIN */
.main {
  flex:1;
  padding:20px;
}

/* PROFILE */
.profile {
  display:flex;
  align-items:center;
  gap:20px;
  margin-bottom:20px;
  background:white;
  padding:20px;
  border-radius:10px;
}

.profile img {
  width:90px;
  height:90px;
  border-radius:50%;
  object-fit:cover;
}

/* TABLE */
table {
  width:100%;
  border-collapse:collapse;
  background:white;
  margin-top:20px;
}

th {
  background:#0a2540;
  color:white;
  padding:10px;
}

td {
  padding:10px;
  text-align:center;
}

/* MOBILE */
@media(max-width:768px) {

  .menu-btn {
    display:block;
  }

  .sidebar {
    position:fixed;
    left:-250px;
    top:0;
    height:100%;
    z-index:1000;
  }

  .sidebar.active {
    left:0;
  }

  .profile {
    flex-direction:column;
    text-align:center;
  }
}
</style>
</head>

<body>

<!-- HEADER -->
<header>
  <span class="menu-btn" onclick="toggleMenu()">☰</span>
  <h2>Student Dashboard</h2>
  <a href="/" style="color:white;">Logout</a>
</header>

<div class="container">

<!-- SIDEBAR -->
<div class="sidebar" id="sidebar">
  <h3>Menu</h3>
  <a href="#">Profile</a>
  <a href="/students/<%= student._id %>/assignments">Assignments</a>
  <a href="/students/<%= student._id %>/attendance">Attendance</a>
  <a href="/students/<%= student._id %>/results">Results</a>
</div>

<!-- MAIN -->
<div class="main">

  <!-- PROFILE -->
  <div class="profile">
    <% if (photoBase64) { %>
      <img src="<%= photoBase64 %>">
    <% } else { %>
      <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png">
    <% } %>

    <div>
      <h2><%= student.fullName %></h2>
      <p>📧 <%= student.email %></p>
      <p>📱 <%= student.phone %></p>
      <p>🏫 <%= student.class %></p>
    </div>
  </div>

  <!-- TIMETABLE -->
  <h3>📅 Timetable</h3>

  <table>
    <tr>
      <th>Day</th>
      <th>Subject</th>
      <th>Time</th>
    </tr>

    <% if (timetable && timetable.length > 0) { %>
      <% timetable.forEach(t => { %>
        <tr>
          <td><%= t.day %></td>
          <td><%= t.subject %></td>
          <td><%= t.time %></td>
        </tr>
      <% }) %>
    <% } else { %>
      <tr><td colspan="3">No timetable</td></tr>
    <% } %>
  </table>

</div>
</div>

<script>
function toggleMenu() {
  document.getElementById("sidebar").classList.toggle("active");
}
</script>

</body>
</html>