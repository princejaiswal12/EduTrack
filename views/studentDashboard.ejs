<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Student Dashboard</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
  body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: #f4f7fa;
  }

  /* HEADER */
  header {
    background: #0a2540;
    color: white;
    padding: 15px 30px;
    display: flex;
    justify-content: space-between;
  }

  /* LAYOUT */
  .container {
    display: flex;
  }

  /* SIDEBAR */
  .sidebar {
    width: 220px;
    background: #0a2540;
    color: white;
    min-height: 100vh;
    padding: 20px;
  }

  .sidebar h3 {
    color: #4caf50;
  }

  .sidebar a {
    display: block;
    margin: 10px 0;
    color: white;
    text-decoration: none;
  }

  .sidebar a:hover {
    color: #4caf50;
  }

  /* MAIN */
  .main {
    flex: 1;
    padding: 30px;
  }

  /* PROFILE CARD */
  .profile {
    display: flex;
    gap: 20px;
    background: white;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0px 5px 12px rgba(0,0,0,0.1);
    margin-bottom: 25px;
  }

  .profile img {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    border: 3px solid #4caf50;
  }

  .profile h2 {
    margin: 0;
    color: #0a2540;
  }

  /* CARDS */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
  }

  .card {
    background: white;
    padding: 20px;
    border-radius: 12px;
    text-align: center;
    box-shadow: 0px 5px 12px rgba(0,0,0,0.1);
    transition: 0.2s;
  }

  .card:hover {
    transform: translateY(-5px);
  }

  .card h3 {
    margin: 10px 0;
  }

  .green { border-left: 6px solid #4caf50; }
  .blue { border-left: 6px solid #2196f3; }
  .orange { border-left: 6px solid #ff9800; }
  .red { border-left: 6px solid #f44336; }

</style>
</head>

<body>

<header>
  <h2>🎓 Student Dashboard</h2>
  <a href="/login" style="color:white;">Logout</a>
</header>

<div class="container">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <h3>Menu</h3>
    <a href="#">Profile</a>
    <a href="#">Subjects</a>
    <a href="#">Attendance</a>
    <a href="#">Fees</a>
    <a href="#">Timetable</a>
  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- PROFILE -->
    <div class="profile">

      <% if (photoBase64) { %>
        <img src="<%= photoBase64 %>">
      <% } else { %>
        <img src="https://via.placeholder.com/100">
      <% } %>

      <div>
        <h2><%= student.fullName %></h2>
        <p><b>Roll:</b> <%= student.rollNumber %></p>
        <p><b>Email:</b> <%= student.email %></p>
        <p><b>Class:</b> <%= student.class %></p>
        <p><b>Hostel:</b> <%= student.hostel %></p>
      </div>
    </div>

    <!-- DASHBOARD CARDS -->
    <div class="cards">

      <div class="card green">
        <h3>📘 Subjects</h3>
        <p>View enrolled subjects</p>
      </div>

      <div class="card blue">
        <h3>📊 Attendance</h3>
        <p>Track attendance</p>
      </div>

      <div class="card orange">
        <h3>💰 Fees</h3>
        <p>Check payment status</p>
      </div>

      <div class="card red">
        <h3>📅 Timetable</h3>
        <p>View schedule</p>
      </div>

    </div>

  </div>

</div>

</body>
</html>