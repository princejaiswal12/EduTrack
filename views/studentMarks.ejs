<!DOCTYPE html>
<html>
<head>
<title>Results</title>

<style>
body { font-family:'Segoe UI'; padding:20px; background:#f4f7fa; }

table {
  width:100%;
  background:white;
  border-collapse:collapse;
}

th {
  background:#0a2540;
  color:white;
}

td, th {
  padding:10px;
  text-align:center;
}
</style>
</head>

<body>

<h2>📊 My Results</h2>

<table>
<tr>
  <th>Subject</th>
  <th>Marks</th>
  <th>Exam</th>
</tr>

<% marks.forEach(m => { %>
<tr>
  <td><%= m.subject %></td>
  <td><%= m.marks %></td>
  <td><%= m.examType %></td>
</tr>
<% }) %>

</table>

</body>
</html>