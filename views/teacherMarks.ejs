<!DOCTYPE html>
<html>
<head>
<title>Marks</title>

<style>
body { font-family:'Segoe UI'; padding:20px; background:#f4f7fa; }

.card {
  background:white;
  padding:20px;
  border-radius:10px;
  margin-bottom:20px;
}

input, select {
  width:100%;
  padding:8px;
  margin:5px 0;
}

button {
  background:#4caf50;
  color:white;
  padding:8px;
  border:none;
}

table {
  width:100%;
  background:white;
  border-collapse:collapse;
}

th {
  background:#0a2540;
  color:white;
}

td, th {
  padding:10px;
  text-align:center;
}
</style>
</head>

<body>

<h2>📊 Add Marks</h2>

<div class="card">

<form action="/marks" method="POST">

  <input type="hidden" name="marks[teacher]" value="<%= teacher.fullName %>">

  <select name="marks[studentName]" required>
    <% students.forEach(s => { %>
      <option value="<%= s.fullName %>"><%= s.fullName %></option>
    <% }) %>
  </select>

  <input name="marks[subject]" placeholder="Subject" required>

  <input type="number" name="marks[marks]" placeholder="Marks" required>

  <input name="marks[examType]" placeholder="Exam Type">

  <button>Add Marks</button>

</form>

</div>

<h2>📋 All Marks</h2>

<table>
<tr>
  <th>Student</th>
  <th>Subject</th>
  <th>Marks</th>
  <th>Exam</th>
</tr>

<% marks.forEach(m => { %>
<tr>
  <td><%= m.studentName %></td>
  <td><%= m.subject %></td>
  <td><%= m.marks %></td>
  <td><%= m.examType %></td>
</tr>
<% }) %>

</table>

</body>
</html>