<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Teacher Dashboard</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
  body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: #f4f7fa;
  }

  /* HEADER */
  header {
    background: #0a2540;
    color: white;
    padding: 15px 30px;
    display: flex;
    justify-content: space-between;
  }

  header a {
    color: white;
    text-decoration: none;
    font-weight: bold;
  }

  /* LAYOUT */
  .container {
    display: flex;
  }

  /* SIDEBAR */
  .sidebar {
    width: 220px;
    background: #0a2540;
    color: white;
    min-height: 100vh;
    padding: 20px;
  }

  .sidebar h3 {
    color: #4caf50;
  }

  .sidebar a {
    display: block;
    margin: 10px 0;
    color: white;
    text-decoration: none;
    padding: 8px;
    border-radius: 6px;
    transition: 0.3s;
  }

  .sidebar a:hover {
    background: #4caf50;
  }

  /* MAIN */
  .main {
    flex: 1;
    padding: 30px;
  }

  /* PROFILE CARD */
  .profile {
    display: flex;
    gap: 20px;
    background: white;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0px 5px 12px rgba(0,0,0,0.1);
    margin-bottom: 25px;
  }

  .profile img {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    border: 3px solid #4caf50;
  }

  .profile h2 {
    margin: 0;
    color: #0a2540;
  }

  /* CARDS */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 25px;
  }

  .card {
    background: white;
    padding: 20px;
    border-radius: 12px;
    text-align: center;
    box-shadow: 0px 5px 12px rgba(0,0,0,0.1);
    transition: 0.2s;
    cursor: pointer;
  }

  .card:hover {
    transform: translateY(-5px);
  }

  .green { border-left: 6px solid #4caf50; }
  .blue { border-left: 6px solid #2196f3; }
  .orange { border-left: 6px solid #ff9800; }
  .purple { border-left: 6px solid #9c27b0; }

  /* TABLE */
  table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0px 5px 12px rgba(0,0,0,0.1);
    margin-top: 15px;
  }

  th {
    background: #0a2540;
    color: white;
    padding: 12px;
  }

  td {
    padding: 10px;
    text-align: center;
  }

  tr:nth-child(even) {
    background: #f9f9f9;
  }

</style>
</head>

<body>

<header>
  <h2>👩‍🏫 Teacher Dashboard</h2>
  <a href="/login">Logout</a>
</header>

<div class="container">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <h3>Menu</h3>
    <a href="#">Profile</a>
    <a href="#">Subjects</a>
    <a href="#">Attendance</a>
    <a href="#">Marks</a>
    <a href="#">Assignments</a>
    <a href="#">Timetable</a>
  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- PROFILE -->
    <div class="profile">
      <% if (photoBase64) { %>
        <img src="<%= photoBase64 %>">
      <% } else { %>
        <img src="https://via.placeholder.com/100">
      <% } %>

      <div>
        <h2><%= teacher.fullName %></h2>
        <p><b>Email:</b> <%= teacher.email %></p>
        <p><b>Subject:</b> <%= teacher.subject %></p>
        <p><b>Department:</b> <%= teacher.department %></p>
      </div>
    </div>

    <!-- QUICK ACTION CARDS -->
    <div class="cards">

      <div class="card green">
        <h3>📘 Subjects</h3>
        <p><%= assignedSubjects.length %> Assigned</p>
      </div>

      <div class="card blue">
        <h3>📊 Attendance</h3>
        <p>Manage attendance</p>
      </div>

      <div class="card orange">
        <h3>📝 Marks</h3>
        <p>Upload results</p>
      </div>

      <div class="card purple">
        <h3>📂 Assignments</h3>
        <p>Manage assignments</p>
      </div>

    </div>

    <!-- SUBJECTS TABLE -->
    <h3>Assigned Subjects</h3>

    <table>
      <tr>
        <th>Subject</th>
        <th>Code</th>
        <th>Department</th>
      </tr>

      <% if (assignedSubjects.length > 0) { %>
        <% assignedSubjects.forEach(sub => { %>
          <tr>
            <td><%= sub.subjectName %></td>
            <td><%= sub.subjectCode %></td>
            <td><%= sub.department %></td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="3">No subjects assigned</td></tr>
      <% } %>
    </table>

    <!-- TIMETABLE -->
    <h3>Timetable</h3>

    <table>
      <tr>
        <th>Day</th>
        <th>Time</th>
        <th>Subject</th>
      </tr>

      <% if (timetable.length > 0) { %>
        <% timetable.forEach(t => { %>
          <tr>
            <td><%= t.day %></td>
            <td><%= t.time %></td>
            <td><%= t.subject %></td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="3">No timetable available</td></tr>
      <% } %>
    </table>

  </div>

</div>

</body>
</html>