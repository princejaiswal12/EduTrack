<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Manage Timetable</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
  body { margin:0; font-family:'Segoe UI'; background:#f4f7fa; }

  header {
    background:#0a2540;
    color:white;
    padding:15px 30px;
  }

  .container { display:flex; }

  .sidebar {
    width:220px;
    background:#0a2540;
    color:white;
    min-height:100vh;
    padding:20px;
  }

  .sidebar a {
    display:block;
    color:white;
    margin:10px 0;
    text-decoration:none;
    padding:8px;
    border-radius:6px;
  }

  .sidebar a:hover { background:#4caf50; }

  .main { flex:1; padding:25px; }

  .card {
    background:white;
    padding:20px;
    border-radius:12px;
    margin-bottom:20px;
    box-shadow:0 5px 12px rgba(0,0,0,0.1);
  }

  input, select {
    width:100%;
    padding:10px;
    margin:8px 0;
    border-radius:6px;
    border:1px solid #ccc;
  }

  .add-btn {
    background:#4caf50;
    color:white;
    width:100%;
    padding:10px;
    border:none;
    border-radius:6px;
  }

  table {
    width:100%;
    border-collapse:collapse;
    background:white;
    border-radius:12px;
    overflow:hidden;
  }

  th {
    background:#0a2540;
    color:white;
    padding:10px;
  }

  td {
    padding:10px;
    text-align:center;
  }

  .btn {
    padding:6px 10px;
    border:none;
    color:white;
    border-radius:6px;
  }

  .edit { background:#2196f3; }
  .delete { background:#f44336; }

</style>
</head>

<body>

<header>
  <h2>📅 Manage Timetable</h2>
</header>

<div class="container">

<!-- SIDEBAR -->
<div class="sidebar">
  <a href="/admin/dashboard">Dashboard</a>
  <a href="/students">Students</a>
  <a href="/teachers">Teachers</a>
  <a href="/subjects">Subjects</a>
  <a href="/timetables">Timetable</a>
</div>

<!-- MAIN -->
<div class="main">

<!-- ADD -->
<div class="card">
  <h3>Add Timetable</h3>

  <form action="/timetables" method="POST">

    <select name="timetable[class]">
      <option>Class 10</option>
      <option>Class 11</option>
      <option>Class 12</option>
      <option>B.Sc</option>
    </select>

    <select name="timetable[subject]">
      <% subjects.forEach(s => { %>
        <option><%= s.subjectName %></option>
      <% }) %>
    </select>

    <select name="timetable[teacher]">
      <% teachers.forEach(t => { %>
        <option><%= t.fullName %></option>
      <% }) %>
    </select>

    <select name="timetable[day]">
      <option>Monday</option>
      <option>Tuesday</option>
      <option>Wednesday</option>
      <option>Thursday</option>
      <option>Friday</option>
    </select>

    <input type="time" name="timetable[time]">

    <button class="add-btn">Add Timetable</button>
  </form>
</div>

<!-- TABLE -->
<table>
  <tr>
    <th>Class</th>
    <th>Subject</th>
    <th>Teacher</th>
    <th>Day</th>
    <th>Time</th>
    <th>Action</th>
  </tr>

  <% timetables.forEach(t => { %>
    <tr>
      <td><%= t.class %></td>
      <td><%= t.subject %></td>
      <td><%= t.teacher %></td>
      <td><%= t.day %></td>
      <td><%= t.time %></td>

      <td>
        <a href="/timetables/<%= t._id %>/edit">
          <button class="btn edit">Edit</button>
        </a>

        <form action="/timetables/<%= t._id %>?_method=DELETE"
              method="POST" style="display:inline;">
          <button class="btn delete">Delete</button>
        </form>
      </td>
    </tr>
  <% }) %>

</table>

</div>
</div>

</body>
</html>