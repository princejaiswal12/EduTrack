<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ERP Login</title>

<style>
  body {
    margin:0;
    font-family: 'Segoe UI', sans-serif;
    background: linear-gradient(135deg, #0a2540, #4caf50);
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
  }

  .login-box {
    background:white;
    padding:30px;
    border-radius:12px;
    width:350px;
    box-shadow:0 10px 25px rgba(0,0,0,0.2);
  }

  h2 {
    text-align:center;
    margin-bottom:20px;
    color:#0a2540;
  }

  select, input {
    width:100%;
    padding:10px;
    margin:10px 0;
    border-radius:6px;
    border:1px solid #ccc;
  }

  button {
    width:100%;
    padding:10px;
    background:#4caf50;
    border:none;
    color:white;
    font-weight:bold;
    border-radius:6px;
    cursor:pointer;
  }

  button:hover {
    background:#388e3c;
  }

  .demo-box {
    margin-top:15px;
    padding:12px;
    background:#fff3cd;
    border-radius:8px;
    font-size:14px;
  }

  .switch {
    margin-top:15px;
    text-align:center;
  }

  .switch a {
    color:#4caf50;
    text-decoration:none;
    font-weight:bold;
  }

</style>
</head>

<body>

<div class="login-box">

  <h2>ERP Login</h2>

  <form action="/login" method="POST">

    <select name="role" onchange="autofillAdmin(this.value)" required>
      <option value="">Select Role</option>
      <option value="admin">Admin</option>
      <option value="teacher">Teacher</option>
      <option value="student">Student</option>
    </select>

    <input id="name" name="name" placeholder="Enter Name" required>
    <input id="email" name="email" placeholder="Enter Email" required>

    <button type="submit">Login</button>
  </form>

  <!-- DEFAULT ADMIN -->
  <div class="demo-box">
    <b>🔐 Demo Admin</b><br>
    Name: admin<br>
    Email: admin@erp.com
  </div>

  <!-- SWITCH -->
  <div class="switch">
    Don't have an account?
    <a href="/register">Register</a>
  </div>

</div>

<script>
function autofillAdmin(role) {
  if (role === "admin") {
    document.getElementById("name").value = "admin";
    document.getElementById("email").value = "admin@erp.com";
  }
}
</script>

</body>
</html>