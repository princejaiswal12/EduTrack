<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Manage Subjects</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
  body { margin:0; font-family:'Segoe UI'; background:#f4f7fa; }

  header {
    background:#0a2540;
    color:white;
    padding:15px 30px;
  }

  .container { display:flex; }

  .sidebar {
    width:220px;
    background:#0a2540;
    color:white;
    min-height:100vh;
    padding:20px;
  }

  .sidebar a {
    display:block;
    color:white;
    margin:10px 0;
    text-decoration:none;
    padding:8px;
    border-radius:6px;
  }

  .sidebar a:hover { background:#4caf50; }

  .main { flex:1; padding:25px; }

  .card {
    background:white;
    padding:20px;
    border-radius:12px;
    margin-bottom:20px;
    box-shadow:0 5px 12px rgba(0,0,0,0.1);
  }

  input, select {
    width:100%;
    padding:10px;
    margin:8px 0;
    border-radius:6px;
    border:1px solid #ccc;
  }

  .add-btn {
    background:#4caf50;
    color:white;
    width:100%;
    padding:10px;
    border:none;
    border-radius:6px;
  }

  table {
    width:100%;
    border-collapse:collapse;
    background:white;
    border-radius:12px;
    overflow:hidden;
  }

  th {
    background:#0a2540;
    color:white;
    padding:10px;
  }

  td {
    padding:10px;
    text-align:center;
  }

  .btn {
    padding:6px 10px;
    border:none;
    color:white;
    border-radius:6px;
  }

  .edit { background:#2196f3; }
  .delete { background:#f44336; }

</style>
</head>

<body>

<header>
  <h2>📚 Manage Subjects</h2>
</header>

<div class="container">

<!-- SIDEBAR -->
<div class="sidebar">
  <a href="/admin/dashboard">Dashboard</a>
  <a href="/students">Students</a>
  <a href="/teachers">Teachers</a>
  <a href="/subjects">Subjects</a>
</div>

<!-- MAIN -->
<div class="main">

<!-- ADD SUBJECT -->
<div class="card">
  <h3>Add Subject</h3>

  <form action="/subjects" method="POST">

    <input name="subject[subjectName]" placeholder="Subject Name" required>
    <input name="subject[subjectCode]" placeholder="Subject Code" required>

    <select name="subject[department]">
      <option>Science</option>
      <option>Mathematics</option>
      <option>Commerce</option>
      <option>Arts</option>
      <option>Computer Science</option>
    </select>

    <select name="subject[assignedTeacher]">
      <% teachers.forEach(t => { %>
        <option><%= t.fullName %></option>
      <% }) %>
    </select>

    <button class="add-btn">Add Subject</button>
  </form>
</div>

<!-- SUBJECT TABLE -->
<table>
  <tr>
    <th>Name</th>
    <th>Code</th>
    <th>Department</th>
    <th>Teacher</th>
    <th>Action</th>
  </tr>

  <% subjects.forEach(s => { %>
    <tr>
      <td><%= s.subjectName %></td>
      <td><%= s.subjectCode %></td>
      <td><%= s.department %></td>
      <td><%= s.assignedTeacher %></td>

      <td>
        <!-- EDIT -->
        <a href="/subjects/<%= s._id %>/edit">
          <button class="btn edit">Edit</button>
        </a>

        <!-- DELETE -->
        <form action="/subjects/<%= s._id %>?_method=DELETE"
              method="POST" style="display:inline;">
          <button class="btn delete">Delete</button>
        </form>
      </td>
    </tr>
  <% }) %>

</table>

</div>
</div>

</body>
</html>